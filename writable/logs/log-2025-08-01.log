LEFT JOIN `hak_fitur` ON `hak_fitur`.`id_user` = `users`.`id`
LEFT JOIN `unit_kerja_es2` AS `es2` ON `es2`.`id` = `hak_fitur`.`id_es2`
LEFT JOIN `unit_kerja_es3` AS `es3` ON `es3`.`id` = `hak_fitur`.`id_es3`
WHERE EXISTS (SELECT 1 FROM item_inaktif WHERE item_inaktif.id_ba = `berita_acara`.`id`)
ORDER BY `berita_acara`.`tgl_ba` DESC
 LIMIT 10
